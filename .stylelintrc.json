{
  "rules": {
    "indentation": 2,                // Enforces 2 spaces for indentation
    "no-empty-source": true,         // Disallows empty CSS files
    "max-nesting-depth": 3,          // Limits the depth of nesting to 3
    "color-hex-case": "lower",       // Enforces lowercase for hex colors
    "block-no-empty": true           // Disallows empty CSS blocks
  }
}
